rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - user profile data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User metadata collection - stores last reset dates and other metadata
    match /userMeta/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Commitments collection - monthly financial commitments
    match /commitments/{commitmentId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Savings collection - savings goals
    match /savings/{savingsId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
